{
  "name": "autoheal-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"node server.js\" \"npm run dev --workspace=playground\"",
    "build:sdk": "npm run build --workspace=packages/autoheal-sdk",
    "build:playground": "npm run build --workspace=playground",
    "setup": "node packages/autoheal-cli/bin/setup.js"
  },
  "dependencies": {
    "@autoheal/core": "^1.0.2",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.106.1",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
